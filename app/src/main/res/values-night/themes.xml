<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Tap2Lock" parent="Theme.Material3Expressive.DynamicColors.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="Theme.Tap2Lock.CardPreference.Error" parent="Theme.Tap2Lock">
        <item name="cardBackgroundColor">#8C1D18</item>
        <item name="colorOnErrorContainer">#F9DEDC</item>
    </style>

    <style name="Theme.Tap2Lock.CardPreference.Success" parent="Theme.Tap2Lock">
        <item name="cardBackgroundColor">#364B3F</item>
        <item name="colorOnErrorContainer">#A3CFBB</item>
    </style>
</resources>